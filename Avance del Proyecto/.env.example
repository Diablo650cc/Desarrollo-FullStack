# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=proyecto_api

# ============================================
# CONFIGURACIÓN DE JWT
# ============================================
JWT_SECRET=tu_jwt_secret_muy_seguro_aqui_cambiar_en_produccion_12345

# ============================================
# CONFIGURACIÓN DE PAGOS (STRIPE)
# ============================================
# Para testing usa: sk_test_...
# Para producción usa: sk_live_...
STRIPE_SECRET_KEY=sk_test_mock_key_para_desarrollo
STRIPE_PUBLISHABLE_KEY=pk_test_mock_key_para_desarrollo
STRIPE_MODE=test

# ============================================
# CONFIGURACIÓN DE APIS EXTERNAS
# ============================================
# API de tipos de cambio: https://exchangerate-api.com/
# No requiere autenticación para uso básico
EXCHANGE_RATE_API=https://api.exchangerate-api.com/v4/latest/USD
